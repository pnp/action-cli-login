{
  "name": "@pnp/action-cli-login",
  "version": "4.0.0",
  "description": "GitHub Action to log in to a tenant using CLI for Microsoft 365",
  "license": "MIT",
  "type": "module",
  "main": "lib/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnp/action-cli-login.git"
  },
  "homepage": "https://pnp.github.io/action-cli-login/",
  "bugs": {
    "url": "https://github.com/pnp/action-cli-login/issues"
  },
  "scripts": {
    "dev": "concurrently \"npm:watch\" \"npm:package:watch\"",
    "build": "tsc -p .",
    "clean": "rimraf ./lib ./dist",
    "watch": "tsc -w -p .",
    "package": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/index.js --sourcemap --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "package:watch": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/index.js --sourcemap --watch --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "test": "mocha \"lib/**/*.spec.js\"",
    "test:cov": "c8 npm run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "adaptive card",
    "ai builder",
    "azure active directory",
    "azure ad",
    "azure",
    "bookings",
    "dataverse",
    "entra id",
